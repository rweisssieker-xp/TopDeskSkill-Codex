{
  "tenant": {
    "name": "Example TOPdesk tenant",
    "environment": "acceptance"
  },
  "connector": {
    "enabled": false,
    "mode": "exports",
    "base_url_env": "TOPDESK_BASE_URL",
    "username_env": "TOPDESK_USERNAME",
    "password_env": "TOPDESK_APP_PASSWORD"
  },
  "inputs": {
    "baseline_catalog": "tenant-evidence/baseline-field-catalog.csv",
    "current_catalog": "tenant-evidence/current-field-catalog.csv",
    "incidents": "tenant-evidence/incidents.csv",
    "assignments": "tenant-evidence/assignment-transitions.csv",
    "statuses": "tenant-evidence/status-transitions.csv",
    "ai_usage": "tenant-evidence/ai-usage-log.csv",
    "automation_scenarios": "tenant-evidence/automation-scenarios.csv",
    "readiness_checklist": "tenant-evidence/readiness-checklist.csv",
    "digital_twin_baseline": "tenant-evidence/digital-twin-baseline.csv",
    "digital_twin_scenarios": "tenant-evidence/digital-twin-scenarios.csv"
  },
  "modules": {
    "tenant_drift": true,
    "process_debt": true,
    "ai_adoption_ledger": true,
    "automation_sandbox": true,
    "readiness_scoring": true,
    "digital_twin_light": true,
    "executive_narrative": true
  },
  "governance": {
    "owner": "Service intelligence owner",
    "retention_days": 90,
    "pii_policy": "approved exports only",
    "approval_reference": "change-or-project-id",
    "production_gate": "amber"
  },
  "runtime": {
    "state_db": "tenant-output/runtime/service-intelligence.sqlite",
    "monitoring_json": "tenant-output/runtime/runtime-monitoring.json",
    "schedule": {
      "enabled": false,
      "windows_task_name": "TOPdesk Service Intelligence Runtime",
      "daily_at": "06:30"
    }
  }
}

